# Copy to .env.local and fill in real values. NEVER commit .env.local.

# SQLite database — relative to prisma/schema.prisma, resolves to /data/shifa.db
DATABASE_URL="file:../data/shifa.db"

# Public site URL (used for referral links, payment callbacks, emails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Crypto payment gateway (self-hosted). Checkout creates a payment via
# POST {CRYPTO_GATEWAY_URL}/create-payment; the gateway confirms via a signed
# webhook to /api/crypto-webhook.
# CRYPTO_GATEWAY_URL  — base URL of the gateway (default https://pay.shifalabsops.com).
# CRYPTO_WEBHOOK_SECRET — MUST exactly equal the gateway's WEBHOOK_SECRET (verifies webhooks).
CRYPTO_GATEWAY_URL=https://pay.shifalabsops.com
CRYPTO_WEBHOOK_SECRET=

# Auth
JWT_SECRET=
ADMIN_PASSWORD=

# Affiliates
AFFILIATE_DEFAULT_COMMISSION=10
AFFILIATE_MIN_PAYOUT_USDT=25   # minimum payout threshold in USDT (TRC20)
# Pyramid referrals: master override % on direct recruits' sales + sales needed for promotion eligibility
MASTER_OVERRIDE_PERCENT=2.5
MASTER_SALES_THRESHOLD=10

# Email (OPTIONAL — Postal, self-hosted). Leave POSTAL_URL and POSTAL_API_KEY
# BLANK to run without email: everything works, but password reset is
# unavailable and its UI is hidden. To enable, set BOTH — see deploy/postal/README.md.
# (Postal admin → Mail Server → Credentials → API provides the API key.)
POSTAL_URL=
POSTAL_API_KEY=
EMAIL_FROM="Shifa Asia <noreply@example.com>"

# Email the shop owner when a paid order lands. Requires email configured above.
# Leave empty to disable.
ORDER_NOTIFY_EMAIL=

# 32-byte hex key for AES-256-GCM encryption of bank details
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Bearer token protecting /api/cron/nudges (repurchase reminder job)
# Generate with: openssl rand -hex 32
CRON_SECRET=
