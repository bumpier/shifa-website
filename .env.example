# Copy to .env.local and fill in real values. NEVER commit .env.local.

# SQLite database — relative to prisma/schema.prisma, resolves to /data/shifa.db
DATABASE_URL="file:../data/shifa.db"

# Public site URL (used for referral links, payment callbacks, emails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────
# PAYMENTS — turn each method on/off independently. See PAYMENTS-SETUP.md
# ─────────────────────────────────────────────────────────────

# Card payments (Stripe). Set STRIPE_ENABLED=true and fill both keys to go live.
# Dev: with STRIPE_ENABLED=true and no keys, the local /dev/stripe simulator is used.
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=            # sk_live_... or sk_test_... (Stripe Dashboard → Developers → API keys)
STRIPE_WEBHOOK_SECRET=        # whsec_... (from the webhook endpoint you add in Stripe)

# Crypto payments (Heleket: BTC, ETH, USDT, XMR). Defaults ON; set CRYPTO_ENABLED=false to hide.
# Obtain from your Heleket merchant dashboard (Merchant UUID + Payment API key).
# Dev mode: leave HELEKET_MERCHANT_ID empty to use the local /dev/heleket simulator.
# The simulator signs its own test webhooks, so HELEKET_PAYMENT_API_KEY must be set
# to any non-empty value even in dev (use the real key from the dashboard in prod).
CRYPTO_ENABLED=true
HELEKET_MERCHANT_ID=
HELEKET_PAYMENT_API_KEY=

# Auth
JWT_SECRET=
ADMIN_PASSWORD=

# Affiliates
AFFILIATE_DEFAULT_COMMISSION=10
AFFILIATE_MIN_PAYOUT_USDT=25   # minimum payout threshold in USDT (TRC20)
# Pyramid referrals: master override % on direct recruits' sales + sales needed for promotion eligibility
MASTER_OVERRIDE_PERCENT=2.5
MASTER_SALES_THRESHOLD=10

# Email (Postal, self-hosted) — invites, verification, password reset, order emails
# Base URL of your Postal web server and a server API credential
# (Postal admin → Mail Server → Credentials → API)
POSTAL_URL=https://postal.example.com
POSTAL_API_KEY=
EMAIL_FROM="Shifa Asia <noreply@example.com>"

# Where to send a "new paid order" alert to the shop owner (leave empty to disable)
ORDER_NOTIFY_EMAIL=

# 32-byte hex key for AES-256-GCM encryption of bank details
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Bearer token protecting /api/cron/nudges (repurchase reminder job)
# Generate with: openssl rand -hex 32
CRON_SECRET=
