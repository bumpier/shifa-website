# Copy to .env.local and fill in real values. NEVER commit .env.local.

# SQLite database — relative to prisma/schema.prisma, resolves to /data/shifa.db
DATABASE_URL="file:../data/shifa.db"

# Public site URL (used for referral links, payment callbacks, emails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Paykassma — obtain from Paykassma merchant dashboard after approval
PAYKASSMA_API_KEY=
PAYKASSMA_MERCHANT_ID=
PAYKASSMA_SECRET_KEY=
PAYKASSMA_API_URL=
PAYKASSMA_ENV=sandbox

# NOWPayments — for crypto payments (BTC, ETH, USDT, XMR)
# Obtain from https://nowpayments.io/
# Leave empty for dev mode (uses local simulator)
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# Auth
JWT_SECRET=
ADMIN_PASSWORD=

# Affiliates
AFFILIATE_DEFAULT_COMMISSION=10
AFFILIATE_MIN_PAYOUT_AED=100
# Pyramid referrals: master override % on direct recruits' sales + sales needed for promotion eligibility
MASTER_OVERRIDE_PERCENT=2.5
MASTER_SALES_THRESHOLD=10

# Email (Mailgun) — invites, verification, password reset, order emails
# Obtain free account at https://mailgun.com (US) or https://mailgun.eu (EU)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.example.com
EMAIL_FROM="ShifaPK <noreply@mg.example.com>"

# 32-byte hex key for AES-256-GCM encryption of bank details
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# Bearer token protecting /api/cron/nudges (repurchase reminder job)
# Generate with: openssl rand -hex 32
CRON_SECRET=
