# Copy to .env.local and fill in real values. NEVER commit .env.local.

# SQLite database — relative to prisma/schema.prisma, resolves to /data/shifa.db
DATABASE_URL="file:../data/shifa.db"

# Public site URL (used for referral links, payment callbacks, emails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Paykassma — obtain from Paykassma merchant dashboard after approval
PAYKASSMA_API_KEY=
PAYKASSMA_MERCHANT_ID=
PAYKASSMA_SECRET_KEY=
PAYKASSMA_API_URL=
PAYKASSMA_ENV=sandbox

# Auth
JWT_SECRET=
ADMIN_PASSWORD=

# Affiliates
AFFILIATE_DEFAULT_COMMISSION=10
AFFILIATE_MIN_PAYOUT_AED=100

# Email (Resend) — invites, verification, password reset
RESEND_API_KEY=
EMAIL_FROM="Shifa <noreply@example.com>"

# 32-byte hex key for AES-256-GCM encryption of bank details
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=
