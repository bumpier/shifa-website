generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  // Resolves to <project-root>/data/shifa.db — outside /public, never web-accessible
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String
  priceAed    Decimal  @map("price_aed")
  pricePkr    Decimal  @map("price_pkr")
  priceUsd    Decimal  @map("price_usd")
  priceGbp    Decimal  @map("price_gbp")
  priceEur    Decimal  @default(0) @map("price_eur")
  images      String   @default("[]") // JSON array of image paths
  variants    String   @default("[]") // JSON array of {label,priceAed,pricePkr,priceUsd,priceGbp,priceEur}
  stock       Int      @default(0)
  weightGrams Int      @default(0)
  supplyDays  Int      @default(0) @map("supply_days") // days one unit lasts; 0 = never nudge
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Order {
  id              String   @id @default(uuid())
  status          String   @default("pending") // pending | paid | shipped | delivered | cancelled
  customerName    String
  customerEmail   String
  customerPhone   String
  shippingAddress String // JSON
  items           String // JSON [{productId, slug, name, qty, unitPrice, unitPriceUsd}]
  currency        String
  totalAmount     Decimal
  subtotalUsd     Decimal  @default(0) // commission basis (USD ≈ USDT), computed at order time
  paymentRef      String? // crypto payment gateway invoice/payment id
  paymentMethod   String // btc | eth | usdt | xmr
  refCode         String? // affiliate referral code captured from cookie
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  referrals AffiliateReferral[]
  emailLogs EmailLog[]
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String
  role            String    @default("affiliate")
  name            String
  status          String    @default("active") // active | suspended
  emailVerifiedAt DateTime?
  verifyToken     String?   @unique
  resetToken      String?   @unique
  resetTokenExp   DateTime?
  createdAt       DateTime  @default(now())

  affiliateProfile AffiliateProfile?
  usedInvite       AffiliateInvite?
}

model AffiliateProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  referralCode    String   @unique
  commissionRate  Decimal  @default(10.0) // percent
  // USDT (TRC20) payout address — AES-256-GCM encrypted at rest (lib/encrypt.ts)
  usdtAddress     String?
  totalEarned     Decimal  @default(0) // USDT, approved + paid
  totalPaid       Decimal  @default(0) // USDT
  pendingBalance  Decimal  @default(0) // USDT, approved but unpaid
  // Pyramid: set once at registration from the recruit_code cookie, never changed
  recruiterId     String?
  recruiter       AffiliateProfile?  @relation("Recruits", fields: [recruiterId], references: [id])
  recruits        AffiliateProfile[] @relation("Recruits")
  isMaster        Boolean  @default(false)
  masterAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  referrals      AffiliateReferral[]
  payoutRequests PayoutRequest[]
}

model AffiliateReferral {
  id                   String   @id @default(uuid())
  affiliateId          String
  affiliate            AffiliateProfile @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  orderId              String
  order                Order    @relation(fields: [orderId], references: [id])
  orderTotal           Decimal
  currency             String
  commissionRate       Decimal
  commissionAmountUsdt Decimal // USDT (≈ USD); basis = order.subtotalUsd
  status               String   @default("pending") // pending | approved | paid | rejected
  // direct = the referring affiliate's own commission;
  // override = a master's 2.5% cut of a direct recruit's sale, tied to the
  // direct row via parentReferralId and state-changed together with it
  kind                 String   @default("direct") // direct | override
  parentReferralId     String?  @unique
  parentReferral       AffiliateReferral?  @relation("OverrideOf", fields: [parentReferralId], references: [id])
  overrideReferral     AffiliateReferral?  @relation("OverrideOf")
  createdAt            DateTime @default(now())

  @@unique([orderId, kind])
}

model AffiliateInvite {
  id           String    @id @default(uuid())
  token        String    @unique @default(uuid())
  createdAt    DateTime  @default(now())
  expiresAt    DateTime // 48hr TTL
  usedAt       DateTime?
  usedByUserId String?   @unique
  usedByUser   User?     @relation(fields: [usedByUserId], references: [id])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("PACKER") // ADMIN | PACKER
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
}

model PayoutRequest {
  id           String    @id @default(uuid())
  affiliateId  String
  affiliate    AffiliateProfile @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  amount         Decimal // USDT
  currency       String    @default("USDT")
  status         String    @default("requested") // requested | processing | paid | rejected
  walletSnapshot String // JSON {usdtAddress (encrypted), network:"TRC20"} at request time
  txHash         String? // TRC20 transaction hash, set by admin when marking paid
  adminNote      String?
  requestedAt  DateTime  @default(now())
  processedAt  DateTime?
}

model EmailLog {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  type      String   // confirmation | shipped | delivered | nudge
  recipient String
  sentAt    DateTime @default(now())

  @@unique([orderId, type])
}

model EmailOptOut {
  email     String   @id
  createdAt DateTime @default(now())
}
